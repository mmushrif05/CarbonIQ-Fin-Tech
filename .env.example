# ===== CarbonIQ FinTech — Environment Variables =====
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Shared with Core Platform (REQUIRED) ---
# Same values as the main Carbon-Management .env
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_SERVICE_ACCOUNT=base64-encoded-service-account-json
ANTHROPIC_API_KEY=your-anthropic-api-key
DATA_ENCRYPTION_KEY=your-64-char-hex-key

# --- FinTech API Server ---
FINTECH_API_PORT=3001
FINTECH_API_ENABLED=true
NODE_ENV=development

# --- CORS ---
# Comma-separated allowed origins for bank integrations
ALLOWED_ORIGINS=http://localhost:3000,https://carboniq.online

# --- API Key Management ---
# Salt for hashing API keys (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
API_KEY_SALT=generate-a-64-char-hex-string
API_KEY_DEFAULT_RATE_LIMIT=100

# UI Dashboard API key bypass — set this to the key hardcoded in ui/js/agents.js
# so the internal dashboard can call agent endpoints without a Firebase-registered key.
# Format: ck_test_ + exactly 32 alphanumeric characters
UI_API_KEY=ck_test_00000000000000000000000000000000

# --- PCAF Configuration ---
PCAF_VERSION=3.0
# Default attribution factor (1.0 = 100% of emissions attributed to the bank)
PCAF_DEFAULT_ATTRIBUTION=1.0

# --- Taxonomy Versions ---
TAXONOMY_ASEAN_VERSION=3
TAXONOMY_EU_VERSION=2024
TAXONOMY_HK_VERSION=2024

# --- Webhook Configuration ---
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_RETRIES=3
# Secret for signing webhook payloads (HMAC-SHA256)
WEBHOOK_SIGNING_SECRET=generate-a-random-secret

# --- Feature Flags ---
# Enable/disable features as they are built
FF_COVENANT_ENGINE=true
FF_PORTFOLIO_AGGREGATION=true
FF_TAXONOMY_CHECKER=true
FF_CERTIFICATE_GENERATION=false
FF_INSURANCE_OUTPUT=false

# --- Logging ---
LOG_LEVEL=info
# Set to 'true' to log full request/response bodies (development only)
LOG_VERBOSE=false
