{
  "name": "carboniq-fintech",
  "version": "0.1.0",
  "description": "CarbonIQ FinTech — Bank-facing API layer for construction carbon intelligence",
  "license": "Apache-2.0",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "setup:env": "node scripts/generate-env.js",
    "setup:verify": "node scripts/verify-setup.js",
    "setup:seed": "node scripts/seed-demo-data.js",
    "setup:seed-clear": "node scripts/seed-demo-data.js --clear",
    "key:create": "node scripts/create-api-key.js create",
    "key:list": "node scripts/create-api-key.js list",
    "key:revoke": "node scripts/create-api-key.js revoke",
    "key:register-ui": "node scripts/register-ui-key.js"
  },
  "keywords": [
    "carbon",
    "fintech",
    "green-finance",
    "pcaf",
    "taxonomy",
    "construction",
    "embodied-carbon",
    "regtech",
    "green-loans",
    "esg"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@netlify/functions": "^2.8.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "morgan": "^1.10.0",
    "pdfkit": "^0.15.2",
    "serverless-http": "^3.2.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "eslint": "^9.20.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "./tests/setup.js"
    ],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 30,
        "functions": 35,
        "lines": 45,
        "statements": 45
      }
    }
  }
}
