{
  "name": "carboniq-fintech",
  "version": "0.1.0",
  "description": "CarbonIQ FinTech — Bank-facing API layer for construction carbon intelligence",
  "license": "Apache-2.0",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "carbon",
    "fintech",
    "green-finance",
    "pcaf",
    "taxonomy",
    "construction",
    "embodied-carbon",
    "regtech",
    "green-loans",
    "esg"
  ],
  "dependencies": {
    "express": "^4.21.2",
    "firebase-admin": "^12.0.0",
    "joi": "^17.13.3",
    "uuid": "^10.0.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.5.0",
    "pdfkit": "^0.15.2",
    "morgan": "^1.10.0",
    "@netlify/functions": "^2.8.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "eslint": "^9.20.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": ["./tests/setup.js"],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    }
  }
}
